# Site URL — canonical links, sitemap, Open Graph, JSON-LD (prod: https://ds5construction.com)
# Falls back to astro.config site, then localhost in dev
PUBLIC_SITE_URL="http://localhost:4321"

# Full-site "Coming soon" placeholder (true = stub page only)
PUBLIC_COMING_SOON=false

# Contact / quote form (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
CONTACT_FORM_RECIPIENT_EMAIL=
# Set to true to skip DNS MX/A check on the contact form (e.g. offline dev)
CONTACT_SKIP_MX_CHECK=

# Google Place reviews (home page testimonials)
GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
# Same as GOOGLE_PLACE_ID; "View all reviews" link in testimonials
PUBLIC_GOOGLE_PLACE_ID=
