---
import { cn } from '../utils/cn';
import type { SectionGridProps } from '../types';

interface Props extends SectionGridProps {}

const { class: className } = Astro.props;
---

<div
  class={cn(
    'grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-12 lg:gap-20 overflow-hidden',
    className,
  )}
>
  <slot />
</div>
