---
import Icon from './common/Icon.astro';
---

<button
  type="button"
  data-back-link
  class="text-sm text-muted-foreground hover:text-foreground transition-colors cursor-pointer inline-flex items-center gap-1.5"
>
  <Icon name="ArrowLeft" class="h-4 w-4 shrink-0" />
  Back
</button>

<script>
  document
    .querySelector('[data-back-link]')
    ?.addEventListener('click', () => history.back());
</script>
