---
import { cn } from '../utils/cn';
import { EMBLA_AUTOPLAY_INTERVAL_MS, IMAGE_SIZES } from '../config/siteConfig';
import type { Service } from '../types';

interface Props {
  services: Service[];
}

const SERVICES_CAROUSEL_IMAGE_FALLBACK = '/photo/hero.webp';
const { services } = Astro.props;

const items = services.map((service) => ({
  slug: service.slug,
  title: service.title,
  shortTitle: service.shortTitle,
  image:
    typeof service.image === 'string' &&
    service.image.length > 0 &&
    (service.image.startsWith('/') || service.image.startsWith('http'))
      ? service.image
      : SERVICES_CAROUSEL_IMAGE_FALLBACK,
}));
---

{
  items.length > 0 && (
    <div class="mt-8 w-full" data-embla data-loop="true" data-align="center" data-autoplay="true" data-pause-on-hover="true">
      <div class="overflow-hidden" data-embla-viewport>
        <div class="flex -ml-4 md:-ml-5">
          {
            items.map((item, index) => (
              <div
                class="pl-4 md:pl-5 basis-1/2 xl:basis-1/3 py-2 min-w-0 shrink-0 grow-0"
                data-embla-slide
              >
                <a
                  href={`/our-services/${item.slug}`}
                  class="flex flex-col rounded-md origin-center transition-all duration-500 ease-[cubic-bezier(0.22,1,0.36,1)] will-change-transform h-full outline-none ring-0 shadow-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-background scale-95 opacity-85 hover:opacity-100"
                >
                  <div class="relative aspect-4/3 rounded-md overflow-hidden bg-muted shrink-0">
                    <img
                      src={item.image.startsWith('/') || item.image.startsWith('http') ? item.image : '/photo/home/9-2.webp'}
                      alt={item.title}
                      width="280"
                      height="210"
                      class="absolute inset-0 h-full w-full object-cover transition-transform duration-700 ease-[cubic-bezier(0.22,1,0.36,1)]"
                      sizes={IMAGE_SIZES.servicesCarousel}
                      loading="lazy"
                    />
                  </div>
                  <p class="text-sm font-medium mt-2 text-foreground uppercase">{item.shortTitle}</p>
                </a>
              </div>
            ))
          }
        </div>
      </div>
      <div class="flex justify-center gap-2 mt-4" role="tablist" aria-label="Carousel slides">
        {
          items.map((_, index) => (
            <button
              type="button"
              role="tab"
              aria-label={`Go to slide ${index + 1}`}
              data-embla-dot
              class="h-2 rounded-full transition-all duration-400 ease-[cubic-bezier(0.22,1,0.36,1)] focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-background w-2 bg-muted-foreground/40 hover:bg-muted-foreground/60"
            ></button>
          ))
        }
      </div>
    </div>
  )
}

<script>
  import '../scripts/embla.ts';
</script>
