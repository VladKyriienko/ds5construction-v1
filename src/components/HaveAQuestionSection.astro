---
import Section from './Section.astro';
import ContactForm from './ContactForm.astro';
import type { HaveAQuestionSectionProps } from '../types';

interface Props extends HaveAQuestionSectionProps {}

const {
  title = 'Have a question?',
  description = "Leave a message and we'll contact you back",
  variant = 'default',
  id = 'contact',
  class: className,
} = Astro.props;
---

<Section variant={variant} id={id} class={className}>
  <div data-animate-on-scroll>
    <div class="max-w-2xl mx-auto">
      <h2 class="text-center mb-3 sm:mb-4">{title}</h2>
      <p class="text-muted-foreground text-center mb-6 sm:mb-8">{description}</p>
      <ContactForm />
    </div>
  </div>
</Section>
