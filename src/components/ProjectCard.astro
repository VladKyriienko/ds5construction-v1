---
import { cn } from '../utils/cn';
import Button from './common/Button.astro';
import type { ProjectWithCleanDescription } from '../types';
import { IMAGE_SIZES } from '../config/siteConfig';

interface Props {
  project: ProjectWithCleanDescription;
  imageSizes?: string;
  imageFallback?: string;
  priority?: boolean;
}

const {
  project,
  imageSizes = IMAGE_SIZES.thirdGrid,
  imageFallback = '/photo/hero.webp',
  priority = false,
} = Astro.props;

const src = project.image ?? imageFallback;
---

<article class="group relative aspect-4/3 w-full overflow-hidden rounded-lg shadow-md">
  <img
    src={src}
    alt={project.title}
    width="440"
    height="330"
    class="absolute inset-0 h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
    sizes={imageSizes}
    loading={priority ? 'eager' : 'lazy'}
    fetchpriority={priority ? 'high' : undefined}
    decoding={priority ? 'sync' : 'async'}
  />
  <div class="absolute bottom-0 left-0 right-0 bg-black/70 px-4 py-4 z-5 dark:bg-black/80">
    <h3 class="text-primary-foreground">{project.title}</h3>
  </div>
  <div
    class="absolute inset-2 sm:inset-3 z-10 flex flex-col items-center justify-center bg-background/80 p-6 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 rounded-md"
  >
    <h3>{project.title}</h3>
    <p class="text-foreground/95 text-sm mt-3 flex-1 line-clamp-4 max-w-full">
      {project.cleanDescription}
    </p>
    <Button href={`/projects/${project.slug}`} class="mt-4 self-center">Read more</Button>
  </div>
</article>
