---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/common/Button.astro';
import Icon from '../components/common/Icon.astro';
import { buildPageMetadata } from '../lib/metadata';

const metadata = buildPageMetadata({
  title: 'Page not found – DS5 Construction',
  description: 'The page you are looking for does not exist.',
  path: '404',
});
---

<BaseLayout metadata={metadata} showLocalBusinessJsonLd={false}>
  <div class="min-h-screen flex items-center justify-center p-4 bg-background">
    <div class="w-full max-w-md rounded-lg border-0 bg-card shadow-none">
      <div class="flex flex-col items-center text-center space-y-6 p-8">
        <div class="space-y-2">
          <h1 class="text-6xl font-bold text-muted-foreground/60">404</h1>
          <hr class="w-16 mx-auto border-border" />
        </div>
        <div class="space-y-2">
          <h2>Page not found</h2>
          <p class="text-sm text-muted-foreground max-w-sm">
            The page you're looking for doesn't exist or has been moved.
          </p>
        </div>
        <div class="flex flex-col sm:flex-row gap-3 w-full">
          <Button href="/" class="flex-1">
            <Icon name="Home" class="mr-2 h-4 w-4" />
            Go home
          </Button>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
